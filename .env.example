# LLM 配置。真实 Key 只写入本地或服务器 .env，不要提交 GitHub。
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 兼容 DeepSeek 命名，代码会优先读取 LLM_*，也兼容 DEEPSEEK_*。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding 配置。本地默认使用 BAAI/bge-m3。
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_CACHE_SIZE=512

# 知识库与索引路径。
KNOWLEDGE_PATH=data/knowledge/travel_knowledge.json
CHUNKS_PATH=data/chunks.json
FAISS_INDEX_PATH=data/travel.index

# RAG 检索参数。
TOP_K=3
CANDIDATE_K=20
BM25_WEIGHT=0.45
FAISS_WEIGHT=0.55
QUERY_CACHE_SIZE=128
MIN_RETRIEVAL_SCORE=0.35
MIN_RERANK_SCORE=0.42
MIN_RESULT_AGREEMENT=0.18

# 天气工具配置。
# 可选：openmeteo、qweather、amap。
# openmeteo 无需 Key，作为默认 fallback。
WEATHER_PROVIDER=openmeteo
WEATHER_API_KEY=
WEATHER_BASE_URL=https://api.open-meteo.com
OPENMETEO_BASE_URL=https://api.open-meteo.com
QWEATHER_API_KEY=
QWEATHER_BASE_URL=https://devapi.qweather.com

# 地图工具配置。
# 可选：rule、amap。
# rule 表示无 Key 时使用规则行程 fallback。
MAP_PROVIDER=rule
MAP_API_KEY=
MAP_BASE_URL=https://restapi.amap.com
AMAP_API_KEY=

# 前端与日志配置。
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO

# 前端地图可视化配置。真实值写入 frontend/.env.local 或 frontend/.env.production。
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_CODE=
